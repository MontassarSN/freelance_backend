{
  "name": "softyevents",
  "version": "0.0.1",
  "packageManager": "pnpm@8.10.2",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "ts-node-dev -r tsconfig-paths/register -r dotenv/config src/app/main.ts",
    "start": "node -r dotenv/config dist/app/main.js",
    "setup:staging": "scripts/setup-staging.sh",
    "setup:dev": "scripts/setup-dev.sh",
    "local": "scripts/setup-local.sh",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "--------------------test-----------------------------------": "------------------------------------------------",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "--------------------migrations------------------------------": "------------------------------------------------",
    "migration:run": "env-cmd ts-node -r tsconfig-paths/register src/app/database/runners/runMigrations.ts",
    "migration:create": "env-cmd ts-node -r tsconfig-paths/register src/app/database/runners/create-migration.ts",
    "migration:to": "env-cmd ts-node -r tsconfig-paths/register src/app/database/runners/migrateTo.ts",
    "migration:list": "env-cmd ts-node -r tsconfig-paths/register src/app/database/runners/listAppliedMigrations.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/cqrs": "^10.2.7",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/throttler": "^6.2.1",
    "@sentry/nestjs": "^9.1.0",
    "@sentry/profiling-node": "^9.1.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "busboy": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "env-cmd": "^10.1.0",
    "express": "^4.21.0",
    "firebase-admin": "^13.1.0",
    "google-auth-library": "^9.15.0",
    "handlebars": "^4.7.8",
    "helmet": "^8.0.0",
    "iterare": "^1.2.1",
    "kysely": "^0.27.4",
    "mime-types": "^2.1.35",
    "ms": "^2.1.3",
    "nestjs-i18n": "^10.4.9",
    "nestjs-pino": "^4.1.0",
    "nodemailer": "^6.9.16",
    "passport": "^0.7.0",
    "passport-anonymous": "^1.0.1",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth2": "^0.2.0",
    "passport-jwt": "^4.0.1",
    "passport-linkedin": "^1.0.0",
    "passport-linkedin-oauth2": "^2.0.0",
    "pg": "^8.13.0",
    "pino-pretty": "^11.2.2",
    "pnpm": "^9.12.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "ts-node-dev": "^2.0.0",
    "twilio": "^5.4.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/busboy": "^1.5.4",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/mime-types": "^2.1.4",
    "@types/ms": "^2.1.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-anonymous": "^1.0.5",
    "@types/passport-facebook": "^3.0.3",
    "@types/passport-google-oauth2": "^0.1.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-linkedin-oauth2": "^1.5.6",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
